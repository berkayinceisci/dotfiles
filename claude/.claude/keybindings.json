{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Scroll",
      "bindings": {
        "ctrl+end": null,
        "ctrl+y": "scroll:bottom",
        "ctrl+k": "scroll:top"
      }
    },
    {
      "context": "Transcript",
      "bindings": {
        "ctrl+y": "scroll:bottom",
        "ctrl+k": "scroll:top"
      }
    }
  ]
}
