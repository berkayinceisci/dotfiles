#!/bin/bash
# dl - Download media from URLs
#
# Usage: dl <url>           Download video (yt-dlp)
#        dl -o <name> <url> Download video with custom filename (extension added automatically)
#        dl -i <url>        Download image/gif (yt-dlp or curl for direct URLs)

set -euo pipefail

print_usage() {
    echo "Usage: dl <url>           Download video"
    echo "       dl -o <name> <url> Download video with custom filename"
    echo "       dl -i <url>        Download image/gif"
}

require_ytdlp() {
    if ! command -v yt-dlp >/dev/null 2>&1; then
        echo "Error: yt-dlp not found" >&2
        exit 1
    fi
}

download_video() {
    local url="$1"
    local name="${2:-}"
    require_ytdlp
    local -a extra_args=()
    if [[ -n "$name" ]]; then
        extra_args+=(--output "${name}.%(ext)s")
    fi
    local filepath
    filepath=$(yt-dlp --format "bv*[ext=mp4]+ba[ext=m4a]/b[ext=mp4]" "${extra_args[@]}" --print after_move:filepath "$url")
    echo "$filepath"
    if [[ -f "$filepath" ]]; then
        local size
        if [[ "$(uname -s)" == "Darwin" ]]; then
            size=$(stat -f%z "$filepath")
        else
            size=$(stat -c%s "$filepath")
        fi
        echo "Size: $(numfmt --to=iec "$size" 2>/dev/null || echo "${size} bytes")"
    fi
}

download_image() {
    local url="$1"

    # Direct file URL — use curl
    if [[ "$url" =~ \.(jpg|jpeg|png|gif|webp|svg|bmp)(\?.*)?$ ]]; then
        local filename
        filename=$(basename "${url%%\?*}")
        curl -fLo "$filename" "$url"
        echo "$filename"
    # URL with format in query parameter (e.g. Twitter: ?format=jpg)
    elif [[ "$url" =~ [?\&]format=(jpg|jpeg|png|gif|webp) ]]; then
        local ext="${BASH_REMATCH[1]}"
        local base
        base=$(basename "${url%%\?*}")
        local filename="${base}.${ext}"
        curl -fLo "$filename" "$url"
        echo "$filename"
    else
        # Platform URL (Twitter, Instagram, etc.) — use yt-dlp
        require_ytdlp
        yt-dlp --print after_move:filepath "$url"
    fi
}

if [[ $# -eq 0 ]]; then
    print_usage
    exit 1
fi

mode="video"
output_name=""
url=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -i) mode="image"; shift ;;
        -o) output_name="$2"; shift 2 ;;
        *) url="$1"; shift ;;
    esac
done

if [[ -z "$url" ]]; then
    print_usage
    exit 1
fi

case "$mode" in
    video) download_video "$url" "$output_name" ;;
    image) download_image "$url" ;;
esac
