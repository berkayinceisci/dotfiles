#!/bin/bash
set -euo pipefail

REPO_URL="git://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git"
VERSION="${1:-latest}"
TARGET_DIR="${2:-linux}"

if [[ -d "$TARGET_DIR" ]]; then
    echo "Directory '$TARGET_DIR' already exists"
    exit 1
fi

if [[ "$VERSION" == "latest" ]]; then
    TAG=$(git ls-remote --tags --sort='v:refname' "$REPO_URL" | \
          grep -v -- '-rc' | \
          grep -v '{}' | \
          tail -n1 | \
          cut -d'/' -f3)
else
    TAG="v${VERSION}"
fi

if [[ -z "$TAG" ]]; then
    echo "Failed to find a stable kernel tag for version '$VERSION'"
    exit 1
fi

echo "Cloning kernel $TAG into $TARGET_DIR"
git clone --depth 1 --branch "$TAG" "$REPO_URL" "$TARGET_DIR"
