#!/bin/bash
set -euo pipefail

# Show Claude Code cost for a single month across my machines.
# Machines: popos (local) + macos and manjaro (pushed via ccusage-push).
#
# Usage:
#   ccusage-all            # current month (YYYY-MM)
#   ccusage-all 2026-05    # a specific past month

# If not on popos, delegate to popos via SSH (forwarding the month arg).
if [[ "$(hostname)" != "popos" ]]; then
    exec ssh -o ConnectTimeout=5 popos "~/.local/scripts/ccusage-all $*"
fi

# Machine whose pushed data we aggregate (under ~/.claude/remote/<label>).
# Local popos data is always included separately.
PUSHED_MACHINES=("macos" "manjaro")

# Month to report, default current month. Validate YYYY-MM.
MONTH="${1:-$(date +%Y-%m)}"
if [[ ! "$MONTH" =~ ^[0-9]{4}-[0-9]{2}$ ]]; then
    echo "Invalid month: '$MONTH' (expected YYYY-MM)" >&2
    exit 1
fi

# Ensure PATH includes nvm and local scripts (needed for non-interactive SSH)
export PATH="$HOME/.local/scripts:$HOME/.local/bin:$PATH"
for dir in "$HOME"/.nvm/versions/node/*/bin; do
    [[ -d "$dir" ]] && export PATH="$dir:$PATH" && break
done

command -v ccusage >/dev/null || { echo "ccusage not found"; exit 1; }
command -v jq >/dev/null || { echo "jq not found"; exit 1; }

REMOTE_DIR="$HOME/.claude/remote"
WORK_DIR=$(mktemp -d)

# Compute cost from a projects dir for $MONTH and write result to a file.
# Each call gets its own fake home to allow parallel execution.
compute_cost() {
    local label="$1"
    local projects_dir="$2"
    local out_file="$WORK_DIR/cost-$label"

    if [[ ! -d "$projects_dir" ]] || [[ -z "$(ls -A "$projects_dir" 2>/dev/null)" ]]; then
        return
    fi

    local fake_home="$WORK_DIR/home-$label"
    mkdir -p "$fake_home/.claude"
    ln -s "$projects_dir" "$fake_home/.claude/projects"

    local cost
    cost=$(HOME="$fake_home" ccusage monthly --json 2>/dev/null \
        | jq --arg m "$MONTH" \
            '[.monthly[] | select(.month == $m) | .totalCost] | add // 0') || return
    echo "$cost" > "$out_file"
    printf "%-30s \$%.2f\n" "$label" "$cost"
}

# Compute costs for local + pushed machines in parallel
compute_cost "$(hostname)" "$HOME/.claude/projects" &
for label in "${PUSHED_MACHINES[@]}"; do
    compute_cost "$label" "$REMOTE_DIR/$label/projects" &
done
wait

# Sum all costs
GRAND_TOTAL=0
for f in "$WORK_DIR"/cost-*; do
    [[ -f "$f" ]] || continue
    GRAND_TOTAL=$(echo "$GRAND_TOTAL + $(< "$f")" | bc)
done

rm -rf "$WORK_DIR"

echo "---"
printf "%-30s \$%.2f\n" "Total ($MONTH)" "$GRAND_TOTAL"
