#!/bin/bash
set -euo pipefail

# Cross-platform "open" for Linux.
# On macOS, use the native `open` command instead.
#
# When in an SSH session with LC_OPEN_HOST set, SCPs files to the
# local machine's /tmp and opens them there.

if [[ $# -eq 0 ]]; then
    echo "Usage: xopen <file|url> [file|url ...]"
    exit 1
fi

is_remote() {
    [[ -n "${SSH_CONNECTION:-}" && -n "${LC_OPEN_HOST:-}" && "$(hostname)" != "$LC_OPEN_HOST" ]]
}

# Environment prefix for opening GUI apps on the local machine via SSH.
# Linux needs DISPLAY and DBUS; macOS `open` works without them.
REMOTE_OPEN_ENV="export DISPLAY=:0; export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/\$(id -u)/bus; export PATH=\$HOME/.local/scripts:\$PATH"

open_remote() {
    local file="$1"

    # URLs: open on local machine directly
    if [[ "$file" =~ ^https?:// ]]; then
        local escaped
        escaped=$(printf '%q' "$file")
        ssh "$LC_OPEN_HOST" "$REMOTE_OPEN_ENV; xopen $escaped 2>/dev/null || command open $escaped 2>/dev/null" &
        disown
        return
    fi

    # Directories: not practical to forward
    if [[ -d "$file" ]]; then
        echo "Cannot open remote directories on local machine"
        return 1
    fi

    if [[ ! -e "$file" ]]; then
        echo "No such file: $file"
        return 1
    fi

    local abs_path basename remote_host tmp_path escaped
    abs_path="$(realpath "$file")"
    basename="$(basename "$abs_path")"
    remote_host="$(hostname)"
    tmp_path="/tmp/remote-${remote_host}-${basename}"
    escaped=$(printf '%q' "$tmp_path")

    (
        scp -q "$abs_path" "$LC_OPEN_HOST:$tmp_path" && \
        ssh "$LC_OPEN_HOST" "$REMOTE_OPEN_ENV; xopen $escaped 2>/dev/null || command open $escaped 2>/dev/null"
    ) &
    disown
}

open_one() {
    local file="$1"

    # Handle URLs
    if [[ "$file" =~ ^https?:// ]]; then
        if command -v zen >/dev/null 2>&1; then
            zen "$file" &>/dev/null &
            disown
        else
            echo "Zen Browser not found"
            return 1
        fi
        return
    fi

    # Handle directories
    if [[ -d "$file" ]]; then
        if command -v thunar >/dev/null 2>&1; then
            thunar "$file" &>/dev/null &
            disown
        elif command -v nautilus >/dev/null 2>&1; then
            nautilus "$file" &>/dev/null &
            disown
        else
            xdg-open "$file" &>/dev/null &
            disown
        fi
        return
    fi

    # Handle files by extension
    if [[ ! -e "$file" ]]; then
        echo "No such file: $file"
        return 1
    fi
    if [[ "$(uname)" == "Darwin" ]]; then
        command open "$file" &>/dev/null &
    else
        xdg-open "$file" &>/dev/null &
    fi
    disown
}

for arg in "$@"; do
    if is_remote; then
        open_remote "$arg"
    else
        open_one "$arg"
    fi
done
