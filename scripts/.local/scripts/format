#!/bin/bash
# Format files in a directory using the appropriate formatter per language.
# Mirrors the formatter config from nvim conform.nvim.

set -euo pipefail

usage() {
  cat <<EOF
Usage: format [options] [file|directory]

Format a single file or all supported files in a directory.

Options:
  -r          Recurse into subdirectories
  -n          Dry run (show what would be formatted, don't modify)
  -h          Show this help

Supported formats:
  .py         ruff (organize imports + format)
  .rs         rustfmt
  .c .h .cpp  clang-format
  .lua        stylua
  .json .js .ts .css .html
              prettierd or prettier
  .sh .bash
              shfmt
  .tex        latexindent
  .bib        bibtex-tidy
EOF
  exit 0
}

RECURSE=false
DRY_RUN=false

while getopts "rnh" opt; do
  case "$opt" in
    r) RECURSE=true ;;
    n) DRY_RUN=true ;;
    h) usage ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

TARGET="${1:-.}"

# Check if a command exists
has() {
  command -v "$1" &>/dev/null
}

# Pick first available command from arguments
pick() {
  for cmd in "$@"; do
    if has "$cmd"; then
      echo "$cmd"
      return
    fi
  done
  return 1
}

CHANGED=0
UNCHANGED=0
SKIPPED=0
ERRORS=0

format_file() {
  local file="$1"
  # Skip symlinks — atomic-write formatters (shfmt, etc.) would replace the link
  if [[ -L "$file" ]]; then
    return
  fi
  local ext="${file##*.}"
  local cmd=""

  case ".$ext" in
    .py)
      if has ruff; then
        cmd="ruff"
      fi
      ;;
    .rs)
      if has rustfmt; then
        cmd="rustfmt"
      fi
      ;;
    .c | .h | .cpp | .cc | .cxx | .hpp)
      if has clang-format; then
        cmd="clang-format"
      fi
      ;;
    .lua)
      if has stylua; then
        cmd="stylua"
      fi
      ;;
    .json | .js | .ts | .css | .html)
      cmd=$(pick prettierd prettier) || true
      ;;
    .sh | .bash)
      if has shfmt; then
        cmd="shfmt"
      fi
      ;;
    .tex)
      if has latexindent; then
        cmd="latexindent"
      fi
      ;;
    .bib)
      if has bibtex-tidy; then
        cmd="bibtex-tidy"
      fi
      ;;
    *)
      return
      ;;
  esac

  if [[ -z "$cmd" ]]; then
    echo "  SKIP $file (no formatter installed)"
    ((SKIPPED++)) || true
    return
  fi

  if $DRY_RUN; then
    echo "  WOULD format $file ($cmd)"
    return
  fi

  local hash_before
  hash_before=$(md5sum "$file")

  echo "  $cmd: $file"

  case "$cmd" in
    ruff)
      if ! ruff check --select I --fix --quiet "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      if ! ruff format --quiet "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      ;;
    rustfmt)
      if ! rustfmt --edition 2021 "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      ;;
    clang-format)
      if ! clang-format -i "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      ;;
    stylua)
      if ! stylua "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      ;;
    prettierd)
      if ! prettierd "$file" > "$file.prettierd.tmp" 2>&1; then
        rm -f "$file.prettierd.tmp"
        ((ERRORS++)) || true
        return
      fi
      mv "$file.prettierd.tmp" "$file"
      ;;
    prettier)
      if ! prettier --write "$file" &>/dev/null; then
        ((ERRORS++)) || true
        return
      fi
      ;;
    shfmt)
      if ! shfmt -w "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      ;;
    latexindent)
      if ! latexindent -w -s "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      # latexindent creates backup files
      rm -f "${file}.bak"
      rm -f "indent.log"
      ;;
    bibtex-tidy)
      if ! bibtex-tidy --modify "$file" 2>&1; then
        ((ERRORS++)) || true
        return
      fi
      ;;
  esac

  if [[ "$(md5sum "$file")" == "$hash_before" ]]; then
    ((UNCHANGED++)) || true
  else
    ((CHANGED++)) || true
  fi
}

# Single file mode
if [[ -f "$TARGET" ]]; then
  format_file "$TARGET"
  exit 0
fi

if [[ ! -d "$TARGET" ]]; then
  echo "Error: '$TARGET' is not a file or directory"
  exit 1
fi

# Collect files
if $RECURSE; then
  # Use git ls-files to skip gitignored files when inside a repo
  if git -C "$TARGET" rev-parse --show-toplevel &>/dev/null; then
    while IFS= read -r -d '' file; do
      format_file "$file"
    done < <(git -C "$TARGET" ls-files -z --cached --others --exclude-standard | sort -z | while IFS= read -r -d '' rel; do printf '%s\0' "$TARGET/$rel"; done)
  else
    while IFS= read -r -d '' file; do
      format_file "$file"
    done < <(find "$TARGET" -type f -not -path '*/.git/*' -not -path '*/node_modules/*' -not -path '*/__pycache__/*' -not -path '*/target/*' -print0 | sort -z)
  fi
else
  for file in "$TARGET"/*; do
    if [[ -f "$file" ]]; then
      format_file "$file"
    fi
  done
fi

echo ""
echo "Changed: $CHANGED  Unchanged: $UNCHANGED  Skipped: $SKIPPED  Errors: $ERRORS"
