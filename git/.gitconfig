[user]
    name = berkayinceisci
    email = inceisciberkay@gmail.com

[core]
    pager = delta
    editor = vim
    # fsmonitor = true
    fsmonitor = false
    untrackedCache = true
    excludesFile = ~/.gitignore_global

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections
    light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)

[diff]
    algorithm = histogram
    mnemonicPrefix = true
    renames = true

[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit --date=relative

[init]
    defaultBranch = main

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

# Enforce SSH
[url "ssh://git@github.com/"]
    insteadOf = https://github.com/

[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[fetch]
    prune = true
    pruneTags = true
    all = true

[pull]
    rebase = true

[merge]
    # conflictstyle = zdiff3
    conflictstyle = diff3
    autostash = true

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[rerere]
    enabled = true
    autoupdate = true

# jq-sort filter: normalizes key order of tool-rewritten JSON so cosmetic
# reordering produces no git diff. Used by Claude Code's settings.json, which
# is rewritten in Claude's own key order on every save. Gated by .gitattributes
# in the dotfiles repo (filter=jqsort); a defined-but-unused no-op everywhere else
[filter "jqsort"]
    clean = "jq -S . 2>/dev/null || cat"
    smudge = cat

# claude-settings filter: jqsort PLUS normalization of the machine-specific
# absolute paths that the tmux-assistant-resurrect plugin writes into the
# SessionStart/SessionEnd hooks of claude/.claude/settings.json on every tmux
# config load. Keeps that shared, stowed file machine-agnostic; the live file
# keeps whatever path is correct for the local host. Personal profile only --
# the plugin never touches claude-moatlab, which stays on plain jqsort.
[filter "claude-settings"]
    clean = ~/.local/scripts-private/claude-settings-clean-filter
    smudge = cat

# codex-runtime filter: keeps Codex's stowed config declarative by stripping
# local runtime sections before Git stores/compares codex/.codex/config.toml.
# Codex may still keep those sections in the live worktree file.
[filter "codex-runtime"]
    clean = ~/.local/scripts-private/codex-config-clean-filter
    smudge = cat
