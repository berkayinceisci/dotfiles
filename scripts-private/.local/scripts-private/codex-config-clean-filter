#!/usr/bin/env python3
"""Strip local Codex runtime TOML sections before Git stores config.toml."""

from __future__ import annotations

import argparse
import re
import sys


RUNTIME_SECTION_RE = re.compile(r'^\[(projects(?:\.|")|hooks\.state(?:\]|\.))')


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Remove Codex runtime-only sections from TOML on stdin."
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Log stripped section headers to stderr.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    skipping = False
    pending_blank_lines: list[str] = []
    stripped_after_output = False
    wrote_output = False

    for line in sys.stdin:
        if line.startswith("["):
            skipping = bool(RUNTIME_SECTION_RE.match(line))
            if skipping and args.verbose:
                print(f"stripping Codex runtime section: {line.strip()}",
                      file=sys.stderr)
            if skipping:
                if wrote_output:
                    stripped_after_output = True
                pending_blank_lines.clear()
                continue

            if pending_blank_lines:
                for blank_line in pending_blank_lines:
                    sys.stdout.write(blank_line)
                    wrote_output = True
            elif stripped_after_output:
                sys.stdout.write("\n")
                wrote_output = True
            pending_blank_lines.clear()
            stripped_after_output = False
            sys.stdout.write(line)
            wrote_output = True
            continue

        if skipping:
            continue

        if line.strip() == "":
            pending_blank_lines.append(line)
            continue

        for blank_line in pending_blank_lines:
            sys.stdout.write(blank_line)
            wrote_output = True
        pending_blank_lines.clear()
        stripped_after_output = False
        sys.stdout.write(line)
        wrote_output = True

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
